@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<h1 class="text-danger">Se ha producido un error.</h1>
<h2 class="text-danger">No se ha podido procesar la solicitud.</h2>

@if (Model.ShowRequestId)
{
    <p>
        <strong>ID de solicitud:</strong> <code>@Model.RequestId</code>
    </p>
}

<h3>Modo desarrollo</h3>
<p>
    Cambiando al entorno de <strong>Desarrollo</strong> se mostrará información más detallada sobre el error.
</p>
<p>
    <strong>El entorno de desarrollo no debe activarse en aplicaciones desplegadas en producción</strong>,
    ya que puede exponer información sensible de las excepciones a los usuarios.
    Para depuración local, activa el entorno de <strong>Desarrollo</strong> estableciendo la variable de entorno
    <strong>ASPNETCORE_ENVIRONMENT</strong> con el valor <strong>Development</strong> y reiniciando la aplicación.
</p>
